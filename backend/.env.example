# ══════════════════════════════════════════════════════════
# PrumoSST – Variáveis de Ambiente
# Copie para .env e preencha. NUNCA suba o .env pro GitHub!
# ══════════════════════════════════════════════════════════

PORT=3001
NODE_ENV=production

# ── Certificado Digital ───────────────────────────────────
# Railway: cole o Base64 do .pfx (use o CONVERTER_BASE64.html)
PFX_BASE64=cole_aqui_o_base64_do_certificado

# Senha do .pfx
PFX_PASSWORD=sua_senha_aqui

# LOCAL somente (não usar no Railway):
# PFX_PATH=C:\caminho\para\certificado.pfx

# ── Transmissor ───────────────────────────────────────────
TRANSMISSOR_CPF=00000000000
TRANSMISSOR_NOME=Seu Nome Completo

# ── eSocial ───────────────────────────────────────────────
# producao = envia de verdade | homologacao = teste
ESOCIAL_AMBIENTE=producao

# ── Segurança ─────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_forte_aleatoria

# ── CORS ──────────────────────────────────────────────────
# Domínios permitidos (separe por vírgula)
FRONTEND_URL=https://prumosst.com,https://www.prumosst.com
