# ── Configurações do Servidor ──────────────────
PORT=3001
NODE_ENV=development

# ── Certificado Digital ─────────────────────────
# Caminho para o arquivo .pfx (pode ser relativo ou absoluto)
PFX_PATH=./certificado.pfx
PFX_PASSWORD=sua_senha_aqui

# CPF do engenheiro transmissor (sem pontos/traços)
TRANSMISSOR_CPF=00000000000
TRANSMISSOR_NOME=Ellen Cristine

# ── eSocial ─────────────────────────────────────
# producao ou homologacao
ESOCIAL_AMBIENTE=homologacao

# ── Segurança ───────────────────────────────────
JWT_SECRET=troque_por_uma_chave_secreta_longa_aleatoria_aqui
ENCRYPT_KEY=32_chars_exatos_para_aes256_aqui!

# ── CORS ────────────────────────────────────────
# URL do frontend (Cloudflare Pages ou localhost)
FRONTEND_URL=http://localhost:3000
